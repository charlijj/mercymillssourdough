---
import { site } from '../data/menu.js';
import T from './T.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-name">{site.name}</span>
      <p><T en={site.location} zh={site.location_zh} /></p>
      <p class="footer-cert">
        <T en="FOODSAFE Level 1 Certified · British Columbia" zh="FOODSAFE 一级认证 · 卑诗省（BC）" />
      </p>
    </div>

    <nav class="footer-nav">
      <a href="#story"><T en="Our Story" zh="关于我们" /></a>
      <a href="#menu"><T en="Menu" zh="菜单" /></a>
      <a href="#gallery"><T en="Gallery" zh="图库" /></a>
      <a href="#order"><T en="Order" zh="订购" /></a>
      <a href="#newsletter"><T en="Newsletter" zh="订阅" /></a>
    </nav>

    <div class="footer-contact">
      {site.email && <a href={`mailto:${site.email}`}>{site.email}</a>}
      <div class="footer-social">
        {site.instagram && <a href={site.instagram} target="_blank" rel="noopener">Instagram</a>}
        {site.facebook && <a href={site.facebook} target="_blank" rel="noopener">Facebook</a>}
      </div>
    </div>
  </div>
  <div class="footer-base">
    <div class="container">
      <p>© {year} {site.name} · {site.domain}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--crust); color: var(--cream); }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2rem;
    padding-top: 3.5rem;
    padding-bottom: 2.5rem;
  }
  .footer-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--wheat);
  }
  .footer-brand p { color: rgba(250, 244, 234, 0.7); margin-top: 0.4rem; }
  .footer-cert { font-size: 0.85rem; color: rgba(250, 244, 234, 0.55); }
  .footer-nav { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-nav a, .footer-contact a { color: rgba(250, 244, 234, 0.85); }
  .footer-nav a:hover, .footer-contact a:hover { color: var(--wheat); text-decoration: none; }
  .footer-social { display: flex; gap: 1rem; margin-top: 0.6rem; }
  .footer-base {
    border-top: 1px solid rgba(250, 244, 234, 0.12);
    padding: 1.2rem 0;
    font-size: 0.85rem;
  }
  .footer-base p { margin: 0; color: rgba(250, 244, 234, 0.6); }

  @media (max-width: 680px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
