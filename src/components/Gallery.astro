---
import T from './T.astro';

// A simple photo catalog. Replace the placeholder images in /public/images
// with real photos and update the `src` / `alt` below.
const photos = [
  { src: '/images/placeholder-loaf.svg', alt: 'Freshly baked country loaf', en: 'Classic Country Loaf', zh: '经典乡村面包' },
  { src: '/images/placeholder-process.svg', alt: 'Sourdough starter bubbling', en: 'The living starter', zh: '鲜活的酵头' },
  { src: '/images/placeholder-loaf.svg', alt: 'Seeded multigrain loaf', en: 'Seeded Multigrain', zh: '多谷物杂粮面包' },
  { src: '/images/placeholder-process.svg', alt: 'Dough being shaped by hand', en: 'Shaping by hand', zh: '手工塑形' },
  { src: '/images/placeholder-loaf.svg', alt: 'Scoring a loaf before baking', en: 'Scored & ready to bake', zh: '划纹待烤' },
  { src: '/images/placeholder-process.svg', alt: 'Golden crust close up', en: 'That golden crust', zh: '金黄外壳' },
];
---

<section id="gallery" class="bg-crust">
  <div class="container">
    <div class="gallery-head">
      <span class="eyebrow"><T en="Gallery" zh="图库" /></span>
      <h2><T en="From starter to table" zh="从酵头到餐桌" /></h2>
      <p class="section-lead gallery-lead">
        <T en="A look at the loaves and the process behind them." zh="一览我们的面包与背后的制作过程。" />
      </p>
    </div>

    <div class="gallery-grid">
      {photos.map((p) => (
        <figure class="tile">
          <img src={p.src} alt={p.alt} loading="lazy" />
          <figcaption><T en={p.en} zh={p.zh} /></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-head { max-width: 720px; margin-bottom: 3rem; }
  .gallery-lead { color: rgba(250, 244, 234, 0.85); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.2rem;
  }
  .tile {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--crust-soft);
  }
  .tile img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .tile:hover img { transform: scale(1.05); }
  .tile figcaption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 1.4rem 1rem 0.9rem;
    color: var(--cream);
    font-weight: 500;
    font-size: 0.95rem;
    background: linear-gradient(180deg, transparent, rgba(20, 12, 6, 0.8));
  }
</style>
