---
const steps = [
  {
    num: '01',
    title: 'A Living Starter',
    body: 'It begins with our wild sourdough starter — flour and water, fed daily until it bubbles with natural yeast. No commercial yeast, ever.',
  },
  {
    num: '02',
    title: 'The Slow Rise',
    body: 'We mix, fold, and let the dough ferment slowly over 18–24 hours. Time is the real ingredient — it builds flavor and makes the bread easy to digest.',
  },
  {
    num: '03',
    title: 'Hand Shaped',
    body: 'Every loaf is shaped by hand and rested overnight in the cool, so the crumb sets open and airy and the tang deepens.',
  },
  {
    num: '04',
    title: 'Baked to Gold',
    body: 'Scored and baked in a screaming-hot oven with steam for that signature crackly, deep-golden crust. Cooled, then straight to you.',
  },
];
---

<section id="story" class="bg-cream-deep">
  <div class="container">
    <div class="story-head">
      <span class="eyebrow">How it's made</span>
      <h2>Bread the slow, honest way</h2>
      <p class="section-lead">
        Real sourdough can't be rushed. From a living starter to a golden crust,
        here's the four-day journey every loaf takes before it reaches your table.
      </p>
    </div>

    <ol class="steps">
      {steps.map((s) => (
        <li class="step">
          <span class="step-num">{s.num}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .story-head { max-width: 720px; margin-bottom: 3rem; }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }
  .step {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.8rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(58, 42, 30, 0.06);
  }
  .step-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--amber);
    display: block;
    margin-bottom: 0.6rem;
  }
  .step h3 { margin-bottom: 0.4rem; }
  .step p { margin: 0; color: var(--muted); font-size: 0.98rem; }
</style>
