---
import { site } from '../data/menu.js';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="#top" class="brand">{site.name}</a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav">
      <a href="#story">Our Story</a>
      <a href="#menu">Menu</a>
      <a href="#gallery">Gallery</a>
      <a href="#newsletter">Newsletter</a>
      <a href="#order" class="btn btn-primary nav-cta">Order Now</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 244, 234, 0.9);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid rgba(58, 42, 30, 0.08);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--crust);
    letter-spacing: -0.01em;
  }
  .brand:hover { text-decoration: none; color: var(--amber-deep); }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }
  .site-nav a {
    color: var(--crust-soft);
    font-weight: 500;
    font-size: 0.98rem;
  }
  .site-nav a:hover { color: var(--amber-deep); text-decoration: none; }
  .nav-cta { color: var(--white) !important; padding: 0.5rem 1.2rem; }
  .nav-cta:hover { color: var(--white) !important; }

  .nav-toggle, .nav-burger { display: none; }
  .nav-burger { flex-direction: column; gap: 5px; cursor: pointer; padding: 6px; }
  .nav-burger span {
    width: 26px; height: 2px; background: var(--crust); border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 760px) {
    .nav-burger { display: flex; }
    .site-nav {
      position: absolute;
      top: 68px; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--cream);
      border-bottom: 1px solid rgba(58, 42, 30, 0.1);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .site-nav a { padding: 0.9rem 1.5rem; border-top: 1px solid rgba(58, 42, 30, 0.06); }
    .nav-cta { margin: 0.8rem 1.5rem; text-align: center; }
    .nav-toggle:checked ~ .site-nav { max-height: 420px; }
  }
</style>
