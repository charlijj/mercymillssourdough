---
import T from './T.astro';

// Newsletter signups go through the same Cloudflare Worker as orders
// (POST /api/subscribe): the subscriber gets a welcome email and the owner is
// notified. Configured via PUBLIC_ORDER_API (the Worker base URL).
const ORDER_API = import.meta.env.PUBLIC_ORDER_API || '';
---

<section id="newsletter" class="bg-cream-deep">
  <div class="container newsletter-inner">
    <div class="newsletter-card">
      <span class="eyebrow"><T en="Stay in the loop" zh="保持联系" /></span>
      <h2><T en="Fresh bakes, in your inbox" zh="新鲜烘焙，直达您的邮箱" /></h2>
      <p>
        <T
          en="Join our newsletter for new menu items, seasonal specials, and the occasional baking tip. Sent monthly — never spammy, unsubscribe anytime."
          zh="订阅我们的邮件，获取新品菜单、季节特惠和偶尔的烘焙小贴士。每月一封——绝不打扰，随时可取消订阅。"
        />
      </p>

      <form id="newsletter-form" class="newsletter-form" data-api={ORDER_API}>
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
        <input
          type="email"
          name="email"
          required
          aria-label="Email address"
          data-ph-en="you@example.com"
          data-ph-zh="您的邮箱地址"
          placeholder="you@example.com"
        />
        <button type="submit" class="btn btn-primary"><T en="Subscribe" zh="订阅" /></button>
      </form>
      <p id="newsletter-status" class="newsletter-status" role="status" aria-live="polite"></p>
    </div>
  </div>
</section>

<style>
  .newsletter-inner { display: flex; justify-content: center; }
  .newsletter-card {
    max-width: 640px;
    text-align: center;
    background: var(--white);
    padding: clamp(2rem, 5vw, 3.2rem);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(58, 42, 30, 0.06);
  }
  .newsletter-card p { color: var(--crust-soft); }
  .newsletter-form {
    display: flex;
    gap: 0.7rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .newsletter-form input[type='email'] {
    flex: 1;
    min-width: 220px;
    padding: 0.8rem 1rem;
    border: 1.5px solid rgba(58, 42, 30, 0.15);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 1rem;
  }
  .newsletter-form input:focus {
    outline: none; border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(200, 134, 45, 0.15);
  }
  .newsletter-status { margin: 1rem 0 0; font-weight: 600; min-height: 1.2em; }
  .newsletter-status.ok { color: var(--sage-deep); }
  .newsletter-status.err { color: #b23b2e; }
</style>

<script>
  const form = document.getElementById('newsletter-form');
  const status = document.getElementById('newsletter-status');
  const api = (form && form.dataset.api ? form.dataset.api : '').replace(/\/$/, '');
  const msg = {
    sending: { en: 'Subscribing…', zh: '正在订阅……' },
    ok: { en: 'Thanks for subscribing! 🍞', zh: '订阅成功，谢谢！🍞' },
    err: { en: 'Something went wrong. Please try again.', zh: '出了点问题，请重试。' },
    noapi: { en: 'Signup is not available right now. Please try again later.', zh: '暂时无法订阅，请稍后再试。' },
  };
  const lang = () => (document.documentElement.getAttribute('data-lang') === 'zh' ? 'zh' : 'en');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!api) {
        status.textContent = msg.noapi[lang()];
        status.className = 'newsletter-status err';
        return;
      }
      status.textContent = msg.sending[lang()];
      status.className = 'newsletter-status';
      try {
        const res = await fetch(api + '/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: form.querySelector('[name="email"]').value.trim(),
            botcheck: form.querySelector('[name="botcheck"]').checked,
            lang: lang(),
          }),
        });
        const j = await res.json().catch(() => ({}));
        if (!res.ok || !j.success) throw new Error(j.error || 'failed');
        status.textContent = msg.ok[lang()];
        status.className = 'newsletter-status ok';
        form.reset();
      } catch (err) {
        status.textContent = msg.err[lang()];
        status.className = 'newsletter-status err';
      }
    });
  }
</script>
