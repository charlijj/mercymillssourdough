---
import { menu, site } from '../data/menu.js';
import T from './T.astro';

// Web3Forms access key. Get a free key at https://web3forms.com (enter the
// bakery's Gmail; every submission is emailed there). Set it via the
// PUBLIC_WEB3FORMS_KEY environment variable, or paste it below.
const WEB3FORMS_KEY =
  import.meta.env.PUBLIC_WEB3FORMS_KEY || 'YOUR_WEB3FORMS_ACCESS_KEY';

const quantities = [0, 1, 2, 3, 4, 5];
const fmt = (n) => (Number.isInteger(n) ? `$${n}` : `$${n.toFixed(2)}`);
---

<section id="order">
  <div class="container order-wrap">
    <div class="order-head">
      <span class="eyebrow"><T en="Place an order" zh="在线下单" /></span>
      <h2><T en="Order fresh sourdough" zh="订购新鲜酸种面包" /></h2>
      <p class="section-lead">
        <T
          en="Tell us what you'd like and when. We'll email you back to confirm your total and arrange pickup. Please order at least 3 days before your pickup date."
          zh="告诉我们您想要什么、何时需要。我们会通过邮件与您确认总价并安排自取。请至少在自取日期前 3 天下单。"
        />
      </p>
    </div>

    <form id="order-form" class="order-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value={`New sourdough order — ${site.name}`} />
      <input type="hidden" name="from_name" value={site.name} />
      <input type="hidden" name="fulfilment" value="Pickup (address confirmed by email)" />
      <input type="hidden" name="order_total" id="order-total-field" value="$0" />
      <!-- Honeypot spam trap (leave empty) -->
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

      <fieldset class="fs-items">
        <legend><T en="What would you like?" zh="您想要点什么？" /></legend>
        <div class="item-list">
          {menu.map((item) => (
            <label class="item-row">
              <img class="item-thumb" src={item.image} alt="" loading="lazy" />
              <span class="item-name">
                <span class="item-title"><T en={item.name} zh={item.name_zh} /></span>
                <small>{fmt(item.price)} / <T en={item.unit} zh={item.unit_zh} /></small>
              </span>
              <select name={`qty_${item.id}`} data-price={item.price} aria-label={item.name}>
                {quantities.map((q) => <option value={q}>{q}</option>)}
              </select>
            </label>
          ))}
        </div>
        <div class="order-total">
          <span><T en="Total" zh="总计" /></span>
          <span id="order-total-amount">$0</span>
        </div>
      </fieldset>

      <div class="grid-2">
        <label class="field">
          <span><T en="Your name *" zh="您的姓名 *" /></span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="field">
          <span><T en="Email *" zh="邮箱 *" /></span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label class="field">
          <span><T en="Phone" zh="电话" /></span>
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label class="field">
          <span><T en="Preferred pickup date" zh="期望自取日期" /></span>
          <input type="date" name="preferred_date" id="pickup-date" />
          <small class="field-hint">
            <T en="Orders must be placed at least 3 days in advance." zh="订单须至少提前 3 天下单。" />
          </small>
        </label>
      </div>

      <label class="field">
        <span><T en="Notes & allergy concerns" zh="备注与过敏事项" /></span>
        <textarea
          name="notes"
          rows="3"
          data-ph-en="Please note any allergy concerns or special requests here."
          data-ph-zh="请在此写明任何过敏事项或特殊要求。"
          placeholder="Please note any allergy concerns or special requests here."
        ></textarea>
        <small class="field-hint">
          <T
            en="Have allergies? Our breads may contain wheat, gluten, and eggs. Please list any concerns above so we can help."
            zh="有过敏情况吗？我们的面包可能含有小麦、麸质和鸡蛋。请在上方列出任何顾虑，以便我们协助。"
          />
        </small>
      </label>

      <div class="pickup-note">
        <p>
          <strong><T en="Pickup only." zh="仅限自取。" /></strong>
          <T en="We'll confirm the pickup address and time with you by email." zh="我们将通过邮件与您确认自取地址和时间。" />
        </p>
        <p>
          <strong><T en="Payment:" zh="付款方式：" /></strong>
          <T
            en="cash or e-transfer. Your order is confirmed once payment is received."
            zh="现金或电子转账（E-transfer）。收到付款后订单即确认。"
          />
        </p>
      </div>

      <button type="submit" class="btn btn-primary order-submit">
        <T en="Send Order Request" zh="提交订单请求" />
      </button>

      <p id="order-status" class="order-status" role="status" aria-live="polite"></p>
      <p class="order-fineprint">
        <T
          en="This sends a request, not a payment. We'll reply to confirm your total and details."
          zh="这是提交订单请求，并非付款。我们会回复确认总价与细节。"
        />
      </p>
    </form>
  </div>
</section>

<style>
  .order-wrap { max-width: 780px; }
  .order-head { margin-bottom: 2.5rem; }
  .order-form {
    background: var(--white);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.6rem);
    box-shadow: var(--shadow);
    border: 1px solid rgba(58, 42, 30, 0.06);
  }
  fieldset { border: none; padding: 0; margin: 0 0 1.6rem; }
  legend {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--crust);
    padding: 0;
    margin-bottom: 0.9rem;
  }
  .item-list { display: grid; gap: 0.6rem; }
  .item-row {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.6rem 0.9rem;
    background: var(--cream);
    border-radius: 10px;
    border: 1px solid rgba(58, 42, 30, 0.06);
  }
  .item-thumb {
    width: 54px;
    height: 54px;
    border-radius: 8px;
    object-fit: cover;
    background: var(--cream-deep);
    flex-shrink: 0;
  }
  .item-name { display: flex; flex-direction: column; font-weight: 500; flex: 1; min-width: 0; }
  .item-title { font-weight: 600; }
  .item-name small { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
  .item-row select {
    width: 78px;
    text-align: center;
    padding: 0.55rem 0.6rem;
    cursor: pointer;
    flex-shrink: 0;
  }
  .order-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 1rem;
    padding: 0.9rem 1rem;
    background: var(--crust);
    color: var(--cream);
    border-radius: 10px;
    font-weight: 600;
  }
  #order-total-amount {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--wheat);
  }
  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1.6rem 0;
  }
  .field { display: flex; flex-direction: column; gap: 0.35rem; }
  .field span { font-weight: 500; font-size: 0.92rem; color: var(--crust-soft); }
  .field-hint { color: var(--muted); font-size: 0.8rem; }
  input, textarea, select {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid rgba(58, 42, 30, 0.15);
    border-radius: 9px;
    background: var(--white);
    color: var(--ink);
    width: 100%;
  }
  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(200, 134, 45, 0.15);
  }
  .pickup-note {
    font-size: 0.9rem;
    color: var(--crust-soft);
    background: var(--cream);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    margin: 0 0 1.4rem;
  }
  .pickup-note p { margin: 0 0 0.4rem; }
  .pickup-note p:last-child { margin: 0; }
  .order-submit { width: 100%; margin-top: 0.25rem; font-size: 1.05rem; }
  .order-status { margin: 1rem 0 0; font-weight: 600; text-align: center; }
  .order-status.ok { color: var(--sage-deep); }
  .order-status.err { color: #b23b2e; }
  .order-fineprint { font-size: 0.85rem; color: var(--muted); text-align: center; margin: 0.8rem 0 0; }

  @media (max-width: 560px) {
    .grid-2 { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('order-form');
  const status = document.getElementById('order-status');
  const totalAmount = document.getElementById('order-total-amount');
  const totalField = document.getElementById('order-total-field');
  const dateInput = document.getElementById('pickup-date');

  const msg = {
    none: { en: 'Please choose a quantity for at least one item.', zh: '请至少为一件商品选择数量。' },
    date: { en: 'Please choose a pickup date at least 3 days away.', zh: '请选择至少 3 天后的自取日期。' },
    sending: { en: 'Sending your order…', zh: '正在提交您的订单……' },
    ok: {
      en: 'Thank you! Your order request was sent. We’ll email you to confirm.',
      zh: '谢谢！您的订单请求已提交。我们会通过邮件与您确认。',
    },
    err: {
      en: 'Sorry, something went wrong. Please email us directly and we’ll sort it out.',
      zh: '抱歉，出了点问题。请直接给我们发邮件，我们会为您处理。',
    },
  };
  const lang = () => (document.documentElement.getAttribute('data-lang') === 'zh' ? 'zh' : 'en');

  // Earliest allowed pickup date = today + 3 days.
  const minDate = new Date();
  minDate.setDate(minDate.getDate() + 3);
  const minIso = minDate.toISOString().split('T')[0];
  if (dateInput) dateInput.min = minIso;

  // Live running total.
  const selects = form ? Array.from(form.querySelectorAll('select[data-price]')) : [];
  function recalcTotal() {
    let t = 0;
    selects.forEach((s) => { t += (Number(s.value) || 0) * Number(s.dataset.price || 0); });
    const label = Number.isInteger(t) ? `$${t}` : `$${t.toFixed(2)}`;
    if (totalAmount) totalAmount.textContent = label;
    if (totalField) totalField.value = label;
    return t;
  }
  selects.forEach((s) => s.addEventListener('change', recalcTotal));

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);

      if (recalcTotal() === 0) {
        status.textContent = msg.none[lang()];
        status.className = 'order-status err';
        return;
      }
      if (dateInput && dateInput.value && dateInput.value < minIso) {
        status.textContent = msg.date[lang()];
        status.className = 'order-status err';
        return;
      }

      status.textContent = msg.sending[lang()];
      status.className = 'order-status';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          status.textContent = msg.ok[lang()];
          status.className = 'order-status ok';
          form.reset();
          recalcTotal();
        } else {
          throw new Error(json.message || 'Submission failed');
        }
      } catch (err) {
        status.textContent = msg.err[lang()];
        status.className = 'order-status err';
      }
    });
  }
</script>
