---
import T from './T.astro';
---

<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-inner">
    <span class="eyebrow hero-eyebrow">
      <T en="Naturally leavened · Small batch" zh="天然发酵 · 小批量手作" />
    </span>
    <h1><T en="Small-batch sourdough, baked with patience." zh="小批量酸种面包，慢工细作。" /></h1>
    <p class="hero-sub">
      <T
        en="Hand-shaped loaves and bakes made the slow way — wild yeast, long ferments, and a golden crust worth the wait. Baked in small batches, fresh for local pickup."
        zh="手工塑形，慢火烘焙——天然野生酵母，长时间发酵，金黄酥脆的外壳值得等待。小批量制作，新鲜出炉，本地自取。"
      />
    </p>
    <div class="hero-actions">
      <a href="#order" class="btn btn-primary"><T en="Place an Order" zh="立即订购" /></a>
      <a href="#menu" class="btn btn-outline hero-outline"><T en="See the Menu" zh="查看菜单" /></a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    color: var(--cream);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(30, 20, 12, 0.55) 0%, rgba(30, 20, 12, 0.65) 100%),
      radial-gradient(120% 120% at 70% 20%, #7a5a34 0%, #4a3320 55%, #2a1c10 100%);
    background-size: cover;
    background-position: center;
  }
  /* When a real hero photo is added, set it on .hero-bg like:
     background-image: linear-gradient(...same overlay...), url('/images/hero.jpg'); */
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  .hero-eyebrow { color: var(--wheat); }
  .hero h1 { color: var(--cream); }
  .hero-sub {
    font-size: 1.2rem;
    color: rgba(250, 244, 234, 0.92);
    max-width: 620px;
    margin-bottom: 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-outline { border-color: var(--cream); color: var(--cream); }
  .hero-outline:hover { background: var(--cream); color: var(--crust); }
</style>
