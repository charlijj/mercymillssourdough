---
import { menu } from '../data/menu.js';
import T from './T.astro';

const fmt = (n) => (Number.isInteger(n) ? `$${n}` : `$${n.toFixed(2)}`);

// Mandarin labels for the short product tags.
const tagZh = { Bestseller: '热销', Seasonal: '季节限定' };
---

<section id="menu">
  <div class="container">
    <div class="menu-head">
      <span class="eyebrow"><T en="The Menu" zh="菜单" /></span>
      <h2><T en="This week's bakes" zh="本周烘焙" /></h2>
      <p class="section-lead">
        <T
          en="Fresh out of the oven. Prices are per item — order below and pick up locally."
          zh="新鲜出炉。价格按份计算——在下方下单，即可到店自取。"
        />
      </p>
    </div>

    <div class="menu-search">
      <input
        type="search"
        id="menu-search"
        autocomplete="off"
        aria-label="Search the menu"
        data-ph-en="Search the menu…"
        data-ph-zh="搜索菜单……"
        placeholder="Search the menu…"
      />
    </div>

    <p id="menu-no-results" class="menu-no-results" hidden>
      <T en="No items match your search." zh="没有找到匹配的商品。" />
    </p>

    <div class="menu-grid">
      {menu.map((item) => (
        <article class="card" data-search={`${item.name} ${item.name_zh} ${item.description} ${item.description_zh}`.toLowerCase()}>
          <div class="card-media">
            <img src={item.image} alt={item.name} loading="lazy" />
            {item.tags && item.tags.length > 0 && (
              <span class="card-tag">
                <T en={item.tags[0]} zh={tagZh[item.tags[0]] || item.tags[0]} />
              </span>
            )}
          </div>
          <div class="card-body">
            <div class="card-title-row">
              <h3><T en={item.name} zh={item.name_zh} /></h3>
              <span class="card-price">
                {fmt(item.price)}<small>/<T en={item.unit} zh={item.unit_zh} /></small>
              </span>
            </div>
            <p><T en={item.description} zh={item.description_zh} /></p>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center menu-cta">
      <a href="#order" class="btn btn-primary"><T en="Order Your Loaves" zh="立即下单" /></a>
    </div>
  </div>
</section>

<style>
  .menu-head { max-width: 720px; margin-bottom: 2rem; }
  .menu-search { max-width: 420px; margin: 0 0 2.2rem; }
  .menu-search input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 1.1rem;
    border: 1.5px solid rgba(58, 42, 30, 0.15);
    border-radius: 999px;
    background: var(--white);
    color: var(--ink);
  }
  .menu-search input:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(200, 134, 45, 0.15);
  }
  .menu-no-results { color: var(--muted); font-weight: 500; margin: 0 0 1.5rem; }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.8rem;
  }
  .card {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(58, 42, 30, 0.06);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    display: flex;
    flex-direction: column;
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .card[hidden] { display: none; }
  .card-media { position: relative; aspect-ratio: 4 / 3; background: var(--cream-deep); }
  .card-media img { width: 100%; height: 100%; object-fit: cover; }
  .card-tag {
    position: absolute;
    top: 0.9rem; left: 0.9rem;
    background: var(--amber);
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .card-body { padding: 1.4rem; flex: 1; display: flex; flex-direction: column; }
  .card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .card-title-row h3 { margin: 0; }
  .card-price {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--amber-deep);
    white-space: nowrap;
  }
  .card-price small { font-size: 0.72rem; color: var(--muted); font-weight: 500; }
  .card-body p { margin: 0; color: var(--muted); font-size: 0.96rem; }
  .menu-cta { margin-top: 3rem; }
</style>

<script>
  const search = document.getElementById('menu-search');
  const cards = Array.from(document.querySelectorAll('#menu .card'));
  const noResults = document.getElementById('menu-no-results');

  if (search) {
    search.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const match = !q || (card.dataset.search || '').includes(q);
        card.hidden = !match;
        if (match) visible++;
      });
      if (noResults) noResults.hidden = visible !== 0;
    });
  }
</script>
