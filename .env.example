# Copy this file to ".env" and fill in your real values.
# These are PUBLIC keys (safe to expose in a static site) — they only identify
# which inbox/list a submission goes to, they are not secrets.

# Web3Forms access key for the ORDER form (orders are emailed here).
# Get one free at https://web3forms.com using your mom's Gmail address.
PUBLIC_WEB3FORMS_KEY=

# Newsletter signup POST URL from your MailerLite embedded form (optional).
# See docs/HANDOFF.md for how to find it.
PUBLIC_NEWSLETTER_ACTION=
