# Copy this file to ".env" (in the PROJECT ROOT, not src/) and fill in values.
# PUBLIC_ vars are baked into the static site and are safe to expose.

# Order backend — the Cloudflare Worker base URL (no trailing /api).
# e.g. https://mercy-mills-orders.<your-subdomain>.workers.dev
# When set, orders go through the Worker (customer + owner emails, accept/decline).
PUBLIC_ORDER_API=

# Fallback only: Web3Forms key. Used for orders ONLY if PUBLIC_ORDER_API is
# empty, and still used for the newsletter signup box. Public key, not a secret.
PUBLIC_WEB3FORMS_KEY=
