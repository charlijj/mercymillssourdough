# Copy this file to ".env" (in the PROJECT ROOT, not src/) and fill in the value.
# PUBLIC_ vars are baked into the static site and are safe to expose.

# Cloudflare Worker base URL (no trailing /api). Powers BOTH the order form
# and the newsletter signup.
# e.g. https://mercy-mills-orders.<your-subdomain>.workers.dev
PUBLIC_ORDER_API=
